<file path="bingo/style.css">
/*
    ============================================================
    全体
    ============================================================
*/

* {
    box-sizing: border-box; /* 要素の幅計算を扱いやすくする */
    font-family: sans-serif;
    font-weight: bold;
}

body {
    background-color: #fff7cc;
    color: #ff5500;
    margin: 0;
    /* 全体を中央寄せするFlexbox */
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 5vh;
}

/*
    ============================================================
    当選番号パネル
    ============================================================
*/

.panel {
    width: 240px;
    background-color: white;
    border: 3px solid #ff5500;
    text-align: center;
    font-size: 140px;
    padding: 20px 0;
    margin-bottom: 30px;
}

/*
    ============================================================
    ボタン
    ============================================================
*/

.button {
    width: 140px;
    height: 45px;
    font-size: 18px;
    color: #ff5500;
    background-color: white;
    border: 2px solid #ff5500;
    border-radius: 4px;
    cursor: pointer;
    margin-bottom: 50px;
    transition: background-color 0.2s;
}

/* ホバー時 */
.button:hover {
    background-color: #ffe6d9;
}

/* フォーカス時 */
.button:focus {
    outline: none; /* デフォルトのフォーカスリングを削除 */
    border: 3px solid #ff5500;
}

/*
    ============================================================
    履歴パネル (CSS Grid)
    ============================================================
*/

.board {
    display: grid;
    grid-template-columns: repeat(10, 1fr); /* 10列のグリッドを作る */
    width: 100%;
    max-width: 600px;
    /* 格子の外枠（上と左） */
    border-top: 1px solid #aaa;
    border-left: 1px solid #aaa;
}

.cell {
    background-color: white;
    color: #aaa; /* 未当選はグレー */
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 14px 0;
    font-size: 16px;
    transition: all 0.2s; /* 色が変わるときのアニメーション */
    /* 各マスの右と下にだけ線を引くことで、ボーダーの重複を防ぐ */
    border-right: 1px solid #aaa;
    border-bottom: 1px solid #aaa;
}

/* 当選済みのスタイル（JSで .active が付与されたときに適用） */
.cell.active {
    background-color: #66ffff;
    color: #ff5500;
}
